# Clave de Google AI Studio / Gemini (obligatoria para análisis de PDF e imagen).
# En Vite debe llevar el prefijo VITE_ para exponerla al cliente.
# Copia este archivo a .env.local y reemplaza el valor.
VITE_GEMINI_API_KEY="TU_CLAVE_GEMINI"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
